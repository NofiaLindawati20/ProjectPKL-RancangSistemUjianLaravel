<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.github.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/green_primary"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="←  Ulangan Harian - Matematika"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="01:29:45"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/layoutHeader"
        android:layout_above="@id/layoutBottomGrid"
        android:padding="16dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvInfoNomor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Soal 3 dari 15"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"/>

                <TextView
                    android:id="@+id/tvTandai"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="🔖 Tandai"
                    android:textColor="@color/text_muted"
                    android:textSize="13sp"/>
            </RelativeLayout>

            <TextView
                android:id="@+id/tvTipeSoalLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="#FFCC00"
                android:text="Pilihan Ganda"
                android:textColor="#000000"
                android:textSize="11sp"
                android:textStyle="bold"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:id="@+id/tvSoal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="3. Nilai dari 2x² + 5x - 3 jika x = 2 adalah ..."
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:layout_marginBottom="20dp"/>


            <LinearLayout
                android:id="@+id/layoutPilihanGanda"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <RadioGroup
                    android:id="@+id/rgJawaban"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp">

                    <RadioButton
                        android:id="@+id/rbA"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="A.  13"
                        android:background="@android:drawable/edit_text"
                        android:layout_marginBottom="8dp"
                        android:paddingLeft="12dp"/>

                    <RadioButton
                        android:id="@+id/rbB"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="B.  15"
                        android:background="@android:drawable/edit_text"
                        android:layout_marginBottom="8dp"
                        android:paddingLeft="12dp"
                        android:checked="true"/>

                    <RadioButton
                        android:id="@+id/rbC"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="C.  17"
                        android:background="@android:drawable/edit_text"
                        android:layout_marginBottom="8dp"
                        android:paddingLeft="12dp"/>

                    <RadioButton
                        android:id="@+id/rbD"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="D.  19"
                        android:background="@android:drawable/edit_text"
                        android:layout_marginBottom="8dp"
                        android:paddingLeft="12dp"/>

                    <RadioButton
                        android:id="@+id/rbE"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="E.  21"
                        android:background="@android:drawable/edit_text"
                        android:layout_marginBottom="8dp"
                        android:paddingLeft="12dp"/>
                </RadioGroup>
            </LinearLayout>


            <LinearLayout
                android:id="@+id/layoutUraian"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="24dp">

                <EditText
                    android:id="@+id/etJawabanUraian"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:hint="Ketik jawaban esai Anda di sini..."
                    android:gravity="top|start"
                    android:inputType="textMultiLine"
                    android:scrollbars="vertical"
                    android:background="@android:drawable/edit_text"
                    android:padding="12dp"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/green_light"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Punya jawaban coretan rumus di kertas?"
                        android:textColor="@color/green_primary"
                        android:textStyle="bold"
                        android:textSize="13sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kamu bisa melampirkan foto coretan rumus sebagai bukti."
                        android:textColor="@color/green_primary"
                        android:textSize="11sp"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <Button
                            android:id="@+id/btnUploadFoto"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📸 Upload Foto"
                            android:textSize="12sp"
                            android:backgroundTint="@color/green_primary"
                            android:textColor="#FFFFFF"/>

                        <ImageView
                            android:id="@+id/ivPreviewFoto"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_marginLeft="16dp"
                            android:scaleType="centerCrop"
                            android:background="#D1D1D1"
                            android:src="@android:drawable/ic_menu_camera"/>

                        <TextView
                            android:id="@+id/tvNamaFileFoto"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="8dp"
                            android:text="Belum ada foto terpilih"
                            android:textColor="@color/text_muted"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnSebelumnya"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="‹ SEBELUMNYA"
                    android:textSize="12sp"
                    android:textColor="@color/text_muted"
                    android:backgroundTint="#E0E0E0"
                    android:layout_marginRight="8dp"/>

                <Button
                    android:id="@+id/btnSelanjutnya"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SELANJUTNYA ›"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="@color/green_primary"
                    android:layout_marginLeft="8dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layoutBottomGrid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="16dp">

        <GridView
            android:id="@+id/gvNomorSoal"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:numColumns="8"
            android:horizontalSpacing="6dp"
            android:verticalSpacing="6dp"
            android:gravity="center"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginVertical="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="3">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <View android:layout_width="14dp" android:layout_height="14dp" android:background="@color/green_primary" android:layout_marginRight="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Terjawab" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <View android:layout_width="14dp" android:layout_height="14dp" android:background="#FFFFFF" android:backgroundTint="#D1D1D1" android:layout_marginRight="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Belum Terjawab" android:textSize="11sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <View android:layout_width="14dp" android:layout_height="14dp" android:background="#FFCC00" android:layout_marginRight="4dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ditandai" android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>